<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <!-- Custom Styles -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Toast Container for Dynamic Success Messages (Task 4) -->
  <div id="toastContainer" class="toast-container-custom"></div>

  <!-- Responsive Navbar (Task 3) -->
  <nav class="navbar navbar-expand-lg navbar-dark navbar-custom fixed-top">
    <div class="container">
      <a class="navbar-brand" href="/">
        <i class="bi bi-mortarboard-fill me-2"></i>EduRegister
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
              aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link <%= page === 'home' ? 'active' : '' %>" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#register">Register</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#students">Students</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= page === 'students' ? 'active' : '' %>" href="/students-page">All Records</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Hero Section (Task 3) -->
  <section class="hero-section">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-lg-7 hero-content">
          <h1 class="hero-title">Student Registration System</h1>
          <p class="hero-subtitle">
            A modern, full-stack platform for managing student enrollments.
            Register, view, edit, and manage student records with ease.
          </p>
          <a href="#register" class="btn btn-hero">
            <i class="bi bi-person-plus me-2"></i>Register Now
          </a>
          <div class="hero-stats">
            <div class="hero-stat">
              <div class="stat-number" id="heroStudentCount">0</div>
              <div class="stat-label">Students</div>
            </div>
            <div class="hero-stat">
              <div class="stat-number">5+</div>
              <div class="stat-label">Courses</div>
            </div>
            <div class="hero-stat">
              <div class="stat-number">100%</div>
              <div class="stat-label">Secure</div>
            </div>
          </div>
        </div>
        <div class="col-lg-5 d-none d-lg-block text-center hero-content">
          <i class="bi bi-book-half" style="font-size: 12rem; opacity: 0.2;"></i>
        </div>
      </div>
    </div>
  </section>

  <!-- Server-side validation errors (Task 2) -->
  <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
    <div class="container mt-4">
      <div class="alert alert-danger alert-custom" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Validation Errors:</strong>
        <ul class="mb-0 mt-2">
          <% errors.forEach(function(error) { %>
            <li><%= error %></li>
          <% }); %>
        </ul>
      </div>
    </div>
  <% } %>

  <!-- Registration Form Section (Task 1, 2, 4) -->
  <section id="register" class="section-padding">
    <div class="container">
      <div class="text-center mb-5">
        <h2 class="section-title">Student Registration</h2>
        <p class="section-subtitle">Fill in the form below to register as a new student</p>
      </div>

      <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
          <div class="form-card">
            <!-- Form: Fetch API (Task 5) with traditional POST fallback (Task 1) -->
            <form id="registrationForm" action="/register" method="POST" novalidate>
              <div class="row g-3">
                <!-- Full Name with live character counter (Task 4) -->
                <div class="col-md-6">
                  <label for="fullName" class="form-label">Full Name <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="fullName" name="fullName"
                         placeholder="Enter your full name" maxlength="100"
                         value="<%= typeof formData !== 'undefined' && formData ? formData.fullName || '' : '' %>" required>
                  <div id="nameCharCounter" class="char-counter">0/100 characters</div>
                </div>

                <!-- Email -->
                <div class="col-md-6">
                  <label for="email" class="form-label">Email Address <span class="text-danger">*</span></label>
                  <input type="email" class="form-control" id="email" name="email"
                         placeholder="student@example.com"
                         value="<%= typeof formData !== 'undefined' && formData ? formData.email || '' : '' %>" required>
                </div>

                <!-- Age -->
                <div class="col-md-4">
                  <label for="age" class="form-label">Age <span class="text-danger">*</span></label>
                  <input type="number" class="form-control" id="age" name="age"
                         placeholder="19" min="1" max="120"
                         value="<%= typeof formData !== 'undefined' && formData ? formData.age || '' : '' %>" required>
                </div>

                <!-- Gender -->
                <div class="col-md-4">
                  <label for="gender" class="form-label">Gender <span class="text-danger">*</span></label>
                  <select class="form-select" id="gender" name="gender" required>
                    <option value="">Select gender</option>
                    <option value="male" <%= typeof formData !== 'undefined' && formData && formData.gender === 'male' ? 'selected' : '' %>>Male</option>
                    <option value="female" <%= typeof formData !== 'undefined' && formData && formData.gender === 'female' ? 'selected' : '' %>>Female</option>
                    <option value="other" <%= typeof formData !== 'undefined' && formData && formData.gender === 'other' ? 'selected' : '' %>>Other</option>
                  </select>
                </div>

                <!-- Course -->
                <div class="col-md-4">
                  <label for="course" class="form-label">Course <span class="text-danger">*</span></label>
                  <select class="form-select" id="course" name="course" required>
                    <option value="">Select course</option>
                    <option value="Computer Science" <%= typeof formData !== 'undefined' && formData && formData.course === 'Computer Science' ? 'selected' : '' %>>Computer Science</option>
                    <option value="Information Technology" <%= typeof formData !== 'undefined' && formData && formData.course === 'Information Technology' ? 'selected' : '' %>>Information Technology</option>
                    <option value="Electronics Engineering" <%= typeof formData !== 'undefined' && formData && formData.course === 'Electronics Engineering' ? 'selected' : '' %>>Electronics Engineering</option>
                    <option value="Mechanical Engineering" <%= typeof formData !== 'undefined' && formData && formData.course === 'Mechanical Engineering' ? 'selected' : '' %>>Mechanical Engineering</option>
                    <option value="Business Administration" <%= typeof formData !== 'undefined' && formData && formData.course === 'Business Administration' ? 'selected' : '' %>>Business Administration</option>
                  </select>
                </div>

                <!-- Password with show/hide toggle and strength indicator (Task 4) -->
                <div class="col-12">
                  <label for="password" class="form-label">Password <span class="text-danger">*</span></label>
                  <div class="password-wrapper">
                    <input type="password" class="form-control" id="password" name="password"
                           placeholder="Minimum 8 characters" minlength="8" required>
                    <button type="button" class="password-toggle" id="togglePassword" aria-label="Show password">
                      <i class="bi bi-eye"></i>
                    </button>
                  </div>
                  <div class="strength-bar mt-2">
                    <div class="strength-fill" id="strengthFill"></div>
                  </div>
                  <div class="strength-text" id="strengthText"></div>
                </div>

                <div class="col-12 text-center mt-3">
                  <button type="submit" class="btn btn-register btn-lg">
                    <i class="bi bi-send me-2"></i>Submit Registration
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Student List Section (Task 3, 5) - Dynamic updates via Fetch API -->
  <section id="students" class="section-padding bg-white">
    <div class="container">
      <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
          <h2 class="section-title mb-1">Registered Students</h2>
          <p class="section-subtitle mb-0">
            <span id="studentCount">0</span> student(s) registered
          </p>
        </div>
        <button class="btn btn-outline-primary" onclick="StudentManager.fetchStudents()">
          <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
      </div>

      <div class="students-card">
        <div class="table-responsive">
          <table class="table table-custom table-hover">
            <thead>
              <tr>
                <th>ID</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Age</th>
                <th>Gender</th>
                <th>Course</th>
                <th>Registered</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="studentTableBody">
              <!-- Populated dynamically by students.js -->
            </tbody>
          </table>
        </div>

        <!-- Empty state when no students -->
        <div id="emptyState" class="empty-state">
          <i class="bi bi-inbox d-block"></i>
          <h5>No students registered yet</h5>
          <p class="mb-0">Fill out the registration form above to add the first student.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Edit Student Modal (Task 5 - CRUD Update) -->
  <div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="editModalLabel">
            <i class="bi bi-pencil-square me-2"></i>Edit Student
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form id="editForm">
          <div class="modal-body">
            <input type="hidden" id="editId">
            <div class="mb-3">
              <label for="editFullName" class="form-label">Full Name</label>
              <input type="text" class="form-control" id="editFullName" required>
            </div>
            <div class="mb-3">
              <label for="editEmail" class="form-label">Email</label>
              <input type="email" class="form-control" id="editEmail" required>
            </div>
            <div class="row">
              <div class="col-6 mb-3">
                <label for="editAge" class="form-label">Age</label>
                <input type="number" class="form-control" id="editAge" min="19" required>
              </div>
              <div class="col-6 mb-3">
                <label for="editGender" class="form-label">Gender</label>
                <select class="form-select" id="editGender" required>
                  <option value="male">Male</option>
                  <option value="female">Female</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>
            <div class="mb-3">
              <label for="editCourse" class="form-label">Course</label>
              <select class="form-select" id="editCourse" required>
                <option value="Computer Science">Computer Science</option>
                <option value="Information Technology">Information Technology</option>
                <option value="Electronics Engineering">Electronics Engineering</option>
                <option value="Mechanical Engineering">Mechanical Engineering</option>
                <option value="Business Administration">Business Administration</option>
              </select>
            </div>
            <div class="mb-3">
              <label for="editPassword" class="form-label">New Password <small class="text-muted">(leave blank to keep current)</small></label>
              <input type="password" class="form-control" id="editPassword" minlength="8">
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-register">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Footer (Task 3) -->
  <footer class="footer-custom">
    <div class="container">
      <div class="row">
        <div class="col-md-4 mb-4 mb-md-0">
          <h5 class="text-white mb-3">
            <i class="bi bi-mortarboard-fill me-2"></i>Registration
          </h5>
          <p>A full-stack student registration system built with Node.js, Express, EJS, and Bootstrap 5.</p>
        </div>
        <div class="col-md-4 mb-4 mb-md-0">
          <h6 class="text-white mb-3">Quick Links</h6>
          <ul class="list-unstyled">
            <li><a href="/">Home</a></li>
            <li><a href="#register">Register</a></li>
            <li><a href="#students">Student List</a></li>
            <li><a href="/students-page">All Records</a></li>
          </ul>
        </div>
        <div class="col-md-4">
          <h6 class="text-white mb-3">Tech Stack</h6>
          <p class="small">HTML &bull; CSS &bull; Bootstrap 5 &bull; JavaScript<br>
          Node.js &bull; Express &bull; EJS</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p class="mb-0">&copy; <%= new Date().getFullYear() %> Student Registration System. Internship Project created by purushottam kumar</p>
      </div>
    </div>
  </footer>

  <!-- Bootstrap 5 JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <!-- Client-side validation (Task 2 & 4) -->
  <script src="/js/validation.js"></script>
  <!-- Fetch API CRUD operations (Task 5) -->
  <script src="/js/students.js"></script>
</body>
</html>
