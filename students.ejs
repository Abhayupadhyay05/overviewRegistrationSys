<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark navbar-custom fixed-top">
    <div class="container">
      <a class="navbar-brand" href="/">
        <i class="bi bi-mortarboard-fill me-2"></i>EduRegister
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
              aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/students-page">All Records</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Page Header -->
  <section class="hero-section" style="padding: 120px 0 60px;">
    <div class="container text-center hero-content">
      <h1 class="hero-title"><%= title %></h1>
      <p class="hero-subtitle">Server-rendered student data display (Task 1)</p>
    </div>
  </section>

  <!-- Dynamic Success Message (Task 4) -->
  <% if (typeof successMessage !== 'undefined' && successMessage) { %>
    <div class="container mt-4">
      <div class="alert alert-success alert-custom" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <strong><%= successMessage %></strong>
      </div>
    </div>
  <% } %>

  <!-- Newly Registered Student Details (Task 1 - display submitted data) -->
  <% if (typeof newStudent !== 'undefined' && newStudent) { %>
    <div class="container mt-3">
      <div class="form-card">
        <h4 class="mb-3"><i class="bi bi-person-check me-2 text-success"></i>Registration Details</h4>
        <div class="row g-3">
          <div class="col-md-6">
            <strong>Full Name:</strong>
            <p class="mb-0"><%= newStudent.fullName %></p>
          </div>
          <div class="col-md-6">
            <strong>Email:</strong>
            <p class="mb-0"><%= newStudent.email %></p>
          </div>
          <div class="col-md-4">
            <strong>Age:</strong>
            <p class="mb-0"><%= newStudent.age %></p>
          </div>
          <div class="col-md-4">
            <strong>Gender:</strong>
            <p class="mb-0 text-capitalize"><%= newStudent.gender %></p>
          </div>
          <div class="col-md-4">
            <strong>Course:</strong>
            <p class="mb-0"><%= newStudent.course %></p>
          </div>
          <div class="col-12">
            <strong>Registered At:</strong>
            <p class="mb-0"><%= new Date(newStudent.registeredAt).toLocaleString() %></p>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Student List Section - Server-rendered (Task 1 & 2) -->
  <section class="section-padding">
    <div class="container">
      <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
          <h2 class="section-title mb-1">All Registered Students</h2>
          <p class="section-subtitle mb-0"><%= students.length %> student(s) in memory</p>
        </div>
        <a href="/" class="btn btn-register">
          <i class="bi bi-person-plus me-1"></i>Register New Student
        </a>
      </div>

      <div class="students-card">
        <% if (students.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-inbox d-block"></i>
            <h5>No students registered yet</h5>
            <p class="mb-0">Go to the <a href="/">home page</a> to register a student.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-custom table-hover">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Full Name</th>
                  <th>Email</th>
                  <th>Age</th>
                  <th>Gender</th>
                  <th>Course</th>
                  <th>Registered</th>
                </tr>
              </thead>
              <tbody>
                <% students.forEach(function(student) { %>
                  <tr>
                    <td><%= student.id %></td>
                    <td><strong><%= student.fullName %></strong></td>
                    <td><%= student.email %></td>
                    <td><%= student.age %></td>
                    <td><span class="badge-gender badge-<%= student.gender %>"><%= student.gender %></span></td>
                    <td><%= student.course %></td>
                    <td><%= new Date(student.registeredAt).toLocaleDateString() %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer-custom">
    <div class="container">
      <div class="footer-bottom">
        <p class="mb-0">&copy; <%= new Date().getFullYear() %> Student Registration System. Internship Project.</p>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
